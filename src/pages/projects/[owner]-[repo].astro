---
import { Markdown } from "astro-remote"
import RootLayout from "../../layouts/RootLayout.astro"

type Project = {
  owner: string
  repo: string
  description?: string
  image: string
  website: string
  language: string
  languageColor: string
  stars: number
  forks: string
}

export async function getStaticPaths() {
  const projects = (await fetch(
    "https://gh-pinned.nxl.sh/api/user/roccomaniscalco"
  ).then((res) => res.json())) as Project[]

  return projects.map((project) => ({
    params: {
      owner: project.owner,
      repo: project.repo,
    },
  }))
}

const { owner, repo } = Astro.params 
const projectReadmeText = await fetch(
  `https://raw.githubusercontent.com/${owner}/${repo}/main/README.md`
).then((res) => res.text())

console.log(projectReadmeText)
---

<RootLayout>
  owner: {owner}
  repo: {repo}
  <Markdown content={projectReadmeText} />
</RootLayout>
