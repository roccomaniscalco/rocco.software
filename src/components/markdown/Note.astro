---
import { IconAlertTriangle, IconInfoCircle } from "@tabler/icons-react"

export interface Props {
  type: "note" | "warning"
}

const NOTE_CLASSES = {
  note: "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-100",
  warning:
    "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-100",
}
const NOTE_ICONS = {
  note: IconInfoCircle,
  warning: IconAlertTriangle,
}

const { type } = Astro.props
const Icon = NOTE_ICONS[type]
---

<div class={`${NOTE_CLASSES[type]} my-4 px-4 pt-4 rounded-lg flex gap-2`}>
  <Icon />
  <div class="flex-1">
    <slot />
  </div>
</div>
